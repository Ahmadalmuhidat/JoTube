generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  name      String
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channels      Channel[]
  comments      Comment[]
  playlists     Playlist[]
  views         View[]
  likes         Like[]
  dislikes      Dislike[]
  subscriptions Subscription[]

  @@index([clerkId])
}

model Channel {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Videos in channel
  videos Video[]

  // Subscriptions
  subscribers Subscription[]

  @@index([userId])
}

model Video {
  id           String   @id @default(uuid())
  title        String
  description  String?
  videoUrl     String
  thumbnailUrl String?
  viewCount    Int      @default(0)
  likeCount    Int      @default(0)
  dislikeCount Int      @default(0)
  duration     Int      @default(0)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relationships
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  // Reactions
  likes    Like[]
  dislikes Dislike[]

  // Comments
  comments Comment[]

  // Categories
  categories VideoCategory[]

  // Playlists
  playlistVideos PlaylistVideo[]

  // View logs
  views View[]

  @@index([channelId])
  @@index([createdAt])
}

// Removed VideoLike in favor of Like model below

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([createdAt])
}

model Playlist {
  id          String   @id @default(uuid())
  title       String
  description String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Videos in playlist
  videos PlaylistVideo[]

  @@index([userId])
}

model PlaylistVideo {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relationships
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([playlistId, videoId])
  @@index([videoId])
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  videos VideoCategory[]

  @@index([name])
}

model VideoCategory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relationships
  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([videoId, categoryId])
  @@index([categoryId])
}

model View {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relationships
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([videoId])
}

model Like {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relationships
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([videoId])
}

model Dislike {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relationships
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([videoId])
}

model Subscription {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relationships
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([channelId])
}
